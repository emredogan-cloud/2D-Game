{
  "name": "sky-islands",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Sky Islands — a web-first 2D side-scrolling pixel-art platformer (Phaser 3 + TypeScript + Vite). Phase 0 scaffold.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "20.19.41",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "26.1.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite": "6.4.2",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
